#include <iostream>
using namespace std;

class Graph {
    int a[100][100], n;

public:
    void input() {
        cin >> n;
        for (int i = 0; i < n; i++)
            for (int j = 0; j < n; j++)
                cin >> a[i][j];
    }

    bool check() {
        for (int i = 0; i < n; i++) {
            if (a[i][i] != 0) return false;

            for (int j = 0; j < n; j++) {
                if (i != j && a[i][j] != 1)
                    return false;
            }
        }
        return true;
    }

    void result() {
        int e = 0;

        for (int i = 0; i < n; i++)
            for (int j = i + 1; j < n; j++)
                if (a[i][j] == 1) e++;

        int need = n * (n - 1) / 2;

        cout << "Edges = " << e << "\n";
        cout << "Needed = " << need << "\n";

        if (check())
            cout << "Complete Graph";
        else
            cout << "Not Complete";
    }
};

int main() {
    Graph g;

    g.input();
    g.result();

    return 0;
}
